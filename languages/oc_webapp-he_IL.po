msgid "Original Concepts App"
msgstr "אפליקציית אוריג'ינל קונספטס"

msgid "Settings to fit your pages inside the Original Concepts app"
msgstr "הגדרות להתאמת העמודים בתוך אפליקציית אוריג'ינל קונספטס"

msgid "Comma-separated selectors to hide inside the app"
msgstr "סלקטורים מופרדים בפסיק להסתרה בתוך האפליקציה"

msgid "App WebView user-agent substring"
msgstr "מחרוזת ה-User-Agent של ה-WebView באפליקציה"

msgid "Custom HTTP header for the user-agent (optional)"
msgstr "כותרת HTTP מותאמת ל-User-Agent (אופציונלי)"

msgid "Example: header, .site-footer, #download-app-popup"
msgstr "לדוגמה: header, .site-footer, #download-app-popup"

msgid "Web Application"
msgstr "אפליקציה"

msgid "Restrict to app users only"
msgstr "הגבל למשתמשי אפליקציה בלבד"

msgid "When checked, this coupon works only for shoppers browsing inside the app."
msgstr "כשמסומן, הקופון יעבוד רק עבור לקוחות שגולשים בתוך האפליקציה."

msgid "This coupon can only be used in the app."
msgstr "הקופון לשימוש באפליקציה בלבד"

msgid "OC Webapp: checked GitHub for updates."
msgstr "OC Webapp: נבדקו עדכונים ב-GitHub."

msgid "OC Webapp updates from GitHub releases."
msgstr "OC Webapp מתעדכן מ-Releases ב-GitHub."

msgid "Check for updates now"
msgstr "בדוק עדכונים עכשיו"

msgid "Permission denied."
msgstr "אין הרשאה."
